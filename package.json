{
  "name": "better-omo",
  "version": "1.0.0",
  "description": "Better-OMO - A customized OpenCode plugin based on oh-my-opencode",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema.json": "./dist/better-omo.schema.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "prepublishOnly": "bun run clean && bun run build",
    "test": "echo 'No tests yet' && exit 0",
    "lint": "echo 'No linter configured yet' && exit 0"
  },
  "keywords": [
    "opencode",
    "plugin",
    "ai",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.33",
    "@opencode-ai/sdk": "^1.14.33",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.13",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "bun": {
      "optional": true
    }
  }
}
